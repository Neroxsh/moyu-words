{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/src-tauri/tauri.conf.json",
  "productName": "MoyuWords",
  "version": "0.1.0",
  "identifier": "com.moyu.words",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "摸鱼背词",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 650,
        "center": true,
        "decorations": true,
        "transparent": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/vocab/*"]
  }
}